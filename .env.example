# Polymarket Configuration
POLYMARKET_PRIVATE_KEY=your_polygon_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_polygon_address_here
POLYMARKET_API_KEY=optional_api_key
POLYMARKET_API_SECRET=optional_api_secret
POLYMARKET_API_PASSPHRASE=optional_passphrase

# Pyth Network
PYTH_HERMES_URL=https://hermes.pyth.network

# Risk Management
MAX_POSITION_PERCENT=5.0
MIN_ARB_PROFIT_PERCENT=1.5
MAX_SLIPPAGE_PERCENT=2.0

# Dashboard
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/polybot.log
